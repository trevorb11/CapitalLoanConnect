{
  "manifest_version": 3,
  "name": "TCG Power Dialer",
  "version": "4.5.0",
  "description": "AI-powered sales dialer with Rep Console, click-to-dial, and Salesforce/GHL integration. Click any phone number to dial instantly.",
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://power-dialer-ten.vercel.app/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open TCG Power Dialer",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["https://power-dialer-ten.vercel.app/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Alt+D",
        "mac": "Alt+D"
      },
      "description": "Open TCG Power Dialer side panel"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
